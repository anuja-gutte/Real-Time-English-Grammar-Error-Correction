{
  "manifest_version": 3,
  "name": "Grammar Glow",
  "version": "3.0",
  "description": "Real-time AI grammar correction with confidence-based auto-fix and undo",
  "permissions": ["activeTab", "scripting", "storage", "tabs"],
  "host_permissions": ["http://localhost:5000/*", "<all_urls>"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Grammar Glow",
    "default_icon": {
      "16":  "icon.png",
      "48":  "icon.png",
      "128": "icon.png"
    }
  },
  "icons": {
    "16":  "icon.png",
    "48":  "icon.png",
    "128": "icon.png"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}